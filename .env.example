# ============================================
#   S-ONE BOT — Configuration Environnement
#   Hackend - Systeme.one
# ============================================

# Token Discord du bot
DISCORD_TOKEN=your_discord_bot_token_here

# ID de l'application Discord
CLIENT_ID=your_client_id_here

# Clé de licence pour activer le bot sur un serveur (définie par Hackend)
LICENSE_KEY=SONE-XXXX-XXXX-XXXX-XXXX

# Secret partagé avec n8n pour les webhooks (HMAC SHA-256)
N8N_WEBHOOK_SECRET=your_n8n_secret_here

# URL de base de votre instance n8n
N8N_BASE_URL=https://your-n8n-instance.com

# Webhook n8n — Témoignages (création dossier Drive)
N8N_TESTIMONIAL_CREATE_URL=https://your-n8n-instance.com/webhook/testimonial-create

# Webhook n8n — Témoignages (vérification vidéo)
N8N_TESTIMONIAL_CHECK_URL=https://your-n8n-instance.com/webhook/testimonial-check

# Port pour l'API interne (webhook retour n8n)
API_PORT=3000

# ID Discord de l'utilisateur Hackend (super-admin)
HACKEND_USER_ID=1223607698113695836
